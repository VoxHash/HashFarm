# =============================================================================
# Environment and secrets (never commit)
# =============================================================================
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# Monero / P2Pool local data (large + sensitive)
# =============================================================================
.bitmonero/
.p2pool-data-api/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
monitor/.venv/
monitor/data/
venv/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# =============================================================================
# Logs and runtime noise
# =============================================================================
*.log
*.log.*
logs/
p2pool.log

